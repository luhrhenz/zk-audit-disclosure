# Copy to .env.local and fill in. .env.local is gitignored.

# Secret key (S...) of the testnet identity used to sign the on-chain commit
# transaction. Generate one with:  stellar keys generate auditor --network testnet
# NEVER commit the real value.
AUDITOR_SECRET=S...your-testnet-secret...

# Deployed Soroban verifier contract id (testnet).
NEXT_PUBLIC_CONTRACT_ID=CBFWF7XLNS55UMRAL4BU73NW32RHF2ED3HJAFMJN4Q2URUB52BUDPXMU

# Optional: force the "Submit to Stellar" step into mock mode (true|false).
# Unset → uses DEFAULT_MOCK_STELLAR in app/config.ts.
# NEXT_PUBLIC_MOCK_STELLAR=false
